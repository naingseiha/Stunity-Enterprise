# Stunity Web — copy all variables into Vercel (Project → Settings → Environment Variables).
# Use Production scope. Do not commit real secrets here; NEXT_PUBLIC_* are baked into the client at build time.

# --- Core microservices (must match Cloud Run URLs) ---
NEXT_PUBLIC_AUTH_SERVICE_URL=https://stunity-auth-service-xxxx-uc.a.run.app
NEXT_PUBLIC_SCHOOL_SERVICE_URL=https://stunity-school-service-xxxx-uc.a.run.app
NEXT_PUBLIC_STUDENT_SERVICE_URL=https://stunity-student-service-xxxx-uc.a.run.app
NEXT_PUBLIC_TEACHER_SERVICE_URL=https://stunity-teacher-service-xxxx-uc.a.run.app
NEXT_PUBLIC_CLASS_SERVICE_URL=https://stunity-class-service-xxxx-uc.a.run.app
NEXT_PUBLIC_SUBJECT_SERVICE_URL=https://stunity-subject-service-xxxx-uc.a.run.app
NEXT_PUBLIC_GRADE_SERVICE_URL=https://stunity-grade-service-xxxx-uc.a.run.app
NEXT_PUBLIC_ATTENDANCE_SERVICE_URL=https://stunity-attendance-service-xxxx-uc.a.run.app
NEXT_PUBLIC_TIMETABLE_SERVICE_URL=https://stunity-timetable-service-xxxx-uc.a.run.app
NEXT_PUBLIC_MESSAGING_SERVICE_URL=https://stunity-messaging-service-xxxx-uc.a.run.app
NEXT_PUBLIC_FEED_SERVICE_URL=https://stunity-feed-service-xxxx-uc.a.run.app
NEXT_PUBLIC_CLUB_SERVICE_URL=https://stunity-club-service-xxxx-uc.a.run.app
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=https://stunity-notification-service-xxxx-uc.a.run.app
NEXT_PUBLIC_ANALYTICS_SERVICE_URL=https://stunity-analytics-service-xxxx-uc.a.run.app
NEXT_PUBLIC_AI_SERVICE_URL=https://stunity-ai-service-xxxx-uc.a.run.app
NEXT_PUBLIC_LEARN_SERVICE_URL=https://stunity-learn-service-xxxx-uc.a.run.app

# Optional: override feed base URL if different from NEXT_PUBLIC_FEED_SERVICE_URL
# NEXT_PUBLIC_FEED_API_URL=

# Legacy / media naming (feed often serves media; set to feed URL if no separate media service)
NEXT_PUBLIC_MEDIA_SERVICE_URL=https://stunity-feed-service-xxxx-uc.a.run.app

# Cloudflare R2 public bucket URL (replace placeholder)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

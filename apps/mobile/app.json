{
  "expo": {
    "name": "Stunity",
    "slug": "stunity-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "stunity",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/Stunity-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stunity.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Stunity needs camera access to take photos for posts and profile pictures.",
        "NSPhotoLibraryUsageDescription": "Stunity needs photo library access to share photos in posts.",
        "NSMicrophoneUsageDescription": "Stunity needs microphone access to record videos.",
        "NSFaceIDUsageDescription": "Stunity uses Face ID for secure login.",
        "NSLocationWhenInUseUsageDescription": "Stunity needs your location to verify your check-in at school."
      },
      "newArchEnabled": true
    },
    "android": {
      "package": "com.stunity.mobile",
      "googleServicesFile": "./google-services.json",
      "versionCode": 6,
      "icon": "./assets/android-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-adaptive-foreground.png",
        "backgroundColor": "#0ad2fa"
      },
      "splash": {
        "image": "./assets/Stunity-splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "newArchEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/Stunity-splash.png",
          "imageWidth": 260
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Stunity to access your camera."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Stunity to access your photos."
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "ccd3aea3-ccae-4bec-964a-bd331b2ff5b3"
      }
    }
  }
}

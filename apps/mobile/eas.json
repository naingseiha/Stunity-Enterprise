{
    "cli": {
        "version": ">= 3.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": true
            }
        },
        "preview": {
            "distribution": "internal",
            "node": "20.12.0",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_APP_ENV": "production"
            }
        },
        "production": {
            "autoIncrement": true,
            "node": "20.12.0",
            "env": {
                "EXPO_PUBLIC_APP_ENV": "production"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
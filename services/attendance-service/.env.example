# Copy to .env or set in your host (Cloud Run, etc.). See PRODUCTION_RUNBOOK.md.

# Required in production
DATABASE_URL=postgresql://user:pass@host:5432/db
JWT_SECRET=use-a-long-random-secret

# Service
PORT=3008
# AUTH_SERVICE_URL=http://localhost:3001

# CORS: comma-separated web origins, or * for all (use with care)
# CORS_ORIGIN=https://app.example.com,https://www.example.com

# Optional: set to 0 to allow teacher check-in when not on published timetable
# ATTENDANCE_TIMETABLE_ENFORCE=1

# Stunity Enterprise Production Environment Template
# Use these settings for Google Cloud Run / Secret Manager

# --- DATABASE (Supabase) ---
# Use the Connection Pooler for DATABASE_URL (Port 6543)
# Example: postgresql://postgres.xxxx:[PASSWORD]@aws-0-xxxx.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=your_supabase_pooler_url

# Use the Direct Connection for DIRECT_URL (Port 5432) for migrations
# Example: postgresql://postgres.xxxx:[PASSWORD]@aws-0-xxxx.supabase.com:5432/postgres
DIRECT_URL=your_supabase_direct_url

# --- AUTH ---
JWT_SECRET=your_ultra_secure_random_jwt_secret
REFRESH_TOKEN_SECRET=your_ultra_secure_random_refresh_token_secret
ENCRYPTION_KEY=your_32_character_encryption_key

# --- SERVICE URLS (Cloud Run) ---
# Replace with your actual Cloud Run service URLs after first deployment
AUTH_SERVICE_URL=https://auth-service-xxxx-xx.a.run.app
FEED_SERVICE_URL=https://feed-service-xxxx-xx.a.run.app
# ... and so on for other services

# --- OTHER ---
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
CORS_ORIGIN=https://stunity.com,https://admin.stunity.com

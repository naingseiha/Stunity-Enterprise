# ============================================
# DATABASE
# ============================================
# You can use your real Supabase URL here for local dev (one database).
# Safety: Commands that CHANGE or WIPE data (db push, migrate, seed, reset) are
# BLOCKED when this URL looks like Supabase, so you don't accidentally alter real
# data. Running the app or services (read/write via API) is unchanged.
# To allow those commands (e.g. deploy pipeline), set ALLOW_PRODUCTION_DB=1.
# Runtime: Transaction pooler (port 6543) + ?pgbouncer=true — NOT db.xxx.supabase.co:5432 direct
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations only: Session pooler (port 5432 on pooler host) or direct URL from Supabase dashboard
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Prisma slots per service process (keep low on Supabase Micro: 2–3 local, 3 production)
PRISMA_CONNECTION_LIMIT=3
PRISMA_POOL_TIMEOUT=10
# Local ./quick-start.sh sets DISABLE_DB_KEEPALIVE=1 by default
# DISABLE_DB_KEEPALIVE=1
# Cloud Run deploy defaults this to 1 so liveness checks/cold starts do not burn DB slots
# DISABLE_DB_STARTUP_WARMUP=1
# DB_KEEPALIVE_INTERVAL_MS=240000
# SKIP_DB_MIGRATE=1              # skip prisma migrate on each quick-start
# SKIP_MESSAGING_SERVICE=1       # default in quick-start (messaging archived on mobile)
# See docs/LOCAL_DEV.md and .env.development.example for a separate dev Supabase project

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-this"
# Remember-me style: long-lived tokens until logout
JWT_EXPIRATION="24h"
REFRESH_TOKEN_EXPIRATION="365d"
# Internal service auth token for protected service-to-service endpoints
NOTIFICATION_SERVICE_AUTH_TOKEN="set-a-strong-shared-service-token"

# ============================================
# CLOUDFLARE R2 STORAGE
# ============================================
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="stunity-enterprise"
R2_PUBLIC_URL="https://your-bucket.r2.cloudflarestorage.com"
R2_UPLOAD_CONCURRENCY=3

# ============================================
# MICROSERVICES URLS (local quick-start ports)
# ============================================
API_GATEWAY_URL="http://localhost:3000"
AUTH_SERVICE_URL="http://localhost:3001"
SCHOOL_SERVICE_URL="http://localhost:3002"
STUDENT_SERVICE_URL="http://localhost:3003"
TEACHER_SERVICE_URL="http://localhost:3004"
CLASS_SERVICE_URL="http://localhost:3005"
SUBJECT_SERVICE_URL="http://localhost:3006"
GRADE_SERVICE_URL="http://localhost:3007"
ATTENDANCE_SERVICE_URL="http://localhost:3008"
TIMETABLE_SERVICE_URL="http://localhost:3009"
FEED_SERVICE_URL="http://localhost:3010"
MESSAGING_SERVICE_URL="http://localhost:3011"
CLUB_SERVICE_URL="http://localhost:3012"
NOTIFICATION_SERVICE_URL="http://localhost:3013"
ANALYTICS_SERVICE_URL="http://localhost:3014"
LEARN_SERVICE_URL="http://localhost:3018"
AI_SERVICE_URL="http://localhost:3020"

# ============================================
# NEXT.JS (apps/web)
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_WS_URL="ws://localhost:3006"

# ============================================
# EMAIL (Optional)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@stunity.com"

# ============================================
# PUSH NOTIFICATIONS (Optional)
# ============================================
FCM_SERVER_KEY="your-firebase-server-key"
EXPO_ACCESS_TOKEN="your-expo-access-token"

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN="your-sentry-dsn"
DATADOG_API_KEY="your-datadog-key"

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_SOCIAL_FEED="true"
ENABLE_ELEARNING="false"
ENABLE_ANALYTICS="true"
ENABLE_SEARCH="false"
NEXT_PUBLIC_LEARN_SERVICE_URL=http://localhost:3018

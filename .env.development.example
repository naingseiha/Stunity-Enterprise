# ============================================
# DEVELOPMENT / STAGING Supabase (recommended)
# ============================================
# Copy these values into your local `.env` when using a SEPARATE Supabase
# project from production. Create project: Supabase Dashboard → New project.
#
# See: docs/LOCAL_DEV.md
#
# Quick setup (gitignored files — do not commit):
#   SUPABASE_DEV_DB_PASSWORD='...' SUPABASE_DEV_PUBLISHABLE_KEY='...' ./scripts/setup-dev-supabase-env.sh
#   source scripts/activate-dev-database.sh && ./quick-start-lite.sh
#
# stunity-dev pooler host (example): aws-1-ap-southeast-1.pooler.supabase.com
#
# Transaction pooler (runtime — all microservices):
# DATABASE_URL="postgresql://postgres.[DEV_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Session pooler (migrations only):
# DIRECT_URL="postgresql://postgres.[DEV_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
#
# Mobile Realtime (from Supabase → Project Settings → API):
# EXPO_PUBLIC_SUPABASE_URL=https://[DEV_REF].supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ============================================
# Local dev tuning (quick-start-lite sets most of these)
# ============================================
PRISMA_CONNECTION_LIMIT=2
PRISMA_POOL_TIMEOUT=10
DISABLE_DB_KEEPALIVE=1
DISABLE_DB_STARTUP_WARMUP=1
SKIP_DB_MIGRATE=1
SKIP_MESSAGING_SERVICE=1

# Optional: local Redis (feed cache) — install Redis or use Upstash dev instance
# REDIS_URL="redis://localhost:6379"
